@using TaskManagerMVC.DTOs
@model TaskCreateDTO
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<div class="container">
    <h2 class="text-center text-cute">Criando Tarefa</h2>

    <form class="justify-content-center task-body m-5 p-5" asp-controller="Tasks" asp-action="Create" method="post">
        <div>
            <label formaction="Titulo">Título: </label><br />
            <input type="text" asp-for="Titulo" class="w-100" maxlength="30" /><br />

            <label for="Assunto">Assunto:</label><br />
            <input type="text" asp-for="Assunto" class="w-100" maxlength="30" /><br />

            <label for="Descricao">Descrição:</label><br />
            <input type="text" asp-for="Descricao" class="w-100" maxlength="50" /><br />

            <label for="Prioridade">Prioridade:</label><br />
            <select asp-for="Prioridade" asp-items="@(new SelectList(ViewBag.Prioridades))" class="form-control w-50">
                <option value="">Selecione uma prioridade</option>
            </select><br />

            <div class="w-100 d-flex justify-content-center">
                <button class="btn btn-primary me-3" type="submit">Salvar</button>
                <a class="btn btn-danger" asp-controller="Tasks" asp-action="Index">Cancelar</a>
            </div>
        </div>
    </form>
</div>

